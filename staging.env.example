# Staging Environment Configuration
APP_ENV=staging
APP_DEBUG=true
APP_LOG_LEVEL=DEBUG
CORS_ORIGINS=["https://staging.customer-intelligence.internal"]

# PostgreSQL
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=customer_intelligence
DATABASE_USER=platform_user
DATABASE_PASSWORD=CHANGE_ME

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME
REDIS_DB=0
REDIS_CACHE_TTL_SECONDS=300

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=platform_user
RABBITMQ_PASSWORD=CHANGE_ME

# Security
JWT_SECRET=CHANGE_ME_STAGING_SECRET

# MLOps Config
ENABLE_DRIFT_DETECTION=true
ENABLE_AUTO_ROLLBACK=false
