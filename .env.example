# =============================================================================
# Enterprise AI Customer Intelligence Platform
# Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env with real secrets.
# =============================================================================

# ---- PostgreSQL (used by docker-compose.yml) ----
POSTGRES_USER=platform_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=customer_intelligence

# ---- Database (used by backend/config.py) ----
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=customer_intelligence
DATABASE_USER=platform_user
DATABASE_PASSWORD=CHANGE_ME

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME
REDIS_DB=0
REDIS_CACHE_TTL_SECONDS=300

# ---- RabbitMQ ----
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=platform_user
RABBITMQ_PASSWORD=CHANGE_ME

# ---- Security ----
JWT_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_STRING

# ---- OpenAI ----
OPENAI_API_KEY=sk-CHANGE_ME

# ---- Application ----
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ---- Data Paths ----
DATA_RAW_PATH=data/raw
DATA_PROCESSED_PATH=data/processed
