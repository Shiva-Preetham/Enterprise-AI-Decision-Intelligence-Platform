# Production Environment Configuration
APP_ENV=production
APP_DEBUG=false
APP_LOG_LEVEL=INFO
CORS_ORIGINS=["https://customer-intelligence.internal"]

# PostgreSQL (High Connection Pool for Prod)
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=customer_intelligence
DATABASE_USER=platform_user
DATABASE_PASSWORD=CHANGE_ME

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME
REDIS_DB=0
REDIS_CACHE_TTL_SECONDS=3600 # Longer cache in prod

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=platform_user
RABBITMQ_PASSWORD=CHANGE_ME

# Security
JWT_SECRET=CHANGE_ME_SECURE_PROD_SECRET

# MLOps Config
ENABLE_DRIFT_DETECTION=true
ENABLE_AUTO_ROLLBACK=false
